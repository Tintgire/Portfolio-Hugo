# EmailJS credentials for the Contact form.
#
# These are NOT secrets in the traditional sense — the public key is shipped
# in the JS bundle anyway. But keeping them out of source control means each
# environment (local dev, Vercel preview, Vercel prod) owns its own set, and
# rotation doesn't require a git commit.
#
# Setup:
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Paste your real values below.
# 3. Restart `yarn dev` for Vite to pick up the new env vars.
# 4. On Vercel: Project Settings → Environment Variables → add the same 3 keys.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
